# Percolator API
EXPO_PUBLIC_API_URL=https://api.percolatorlaunch.com

# WebSocket (Helius devnet — replace with your own key for production)
EXPO_PUBLIC_WS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Solana RPC (devnet by default — the app defaults to devnet)
EXPO_PUBLIC_CLUSTER=devnet
EXPO_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Supabase (shared with web app)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
