# Release keystore configuration for Percolator Mobile
# Copy this file to keystore.properties and fill in your values.
# NEVER commit keystore.properties to version control.
#
# To generate a new keystore:
#   keytool -genkeypair -v -storetype PKCS12 \
#     -keystore app/percolator-release.keystore \
#     -alias percolator-release \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -storepass <STRONG_RANDOM_PASSWORD> \
#     -keypass <STRONG_RANDOM_PASSWORD> \
#     -dname "CN=Percolator,O=Percolator,L=Unknown,ST=Unknown,C=US"

storeFile=percolator-release.keystore
storePassword=YOUR_KEYSTORE_PASSWORD_HERE
keyAlias=percolator-release
keyPassword=YOUR_KEY_PASSWORD_HERE
